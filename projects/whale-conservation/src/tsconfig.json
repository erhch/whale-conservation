{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@/*": ["./*"],
      "@common/*": ["./common/*"],
      "@auth/*": ["./auth/*"],
      "@species/*": ["./species/*"],
      "@whales/*": ["./whales/*"],
      "@sightings/*": ["./sightings/*"],
      "@stations/*": ["./stations/*"],
      "@stats/*": ["./stats/*"],
      "@environment/*": ["./environment/*"],
      "@health/*": ["./health/*"]
    }
  },
  "include": ["**/*"],
  "exclude": ["node_modules", "dist"]
}
